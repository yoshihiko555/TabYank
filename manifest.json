{
  "manifest_version": 3,
  "name": "TabYank",
  "version": "1.1.0",
  "description": "選択したタブのURLをクリップボードにコピー",
  "permissions": [
    "tabs"
  ],
  "action": {
    "default_title": "選択タブのURLをコピー",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
